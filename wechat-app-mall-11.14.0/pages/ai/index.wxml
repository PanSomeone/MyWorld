<view class="container">
  <view class="header">
    <text class="title">智能推荐</text>
    <text class="subtitle">不知道吃什么？让AI来推荐</text>
  </view>
  
  <view class="input-area">
    <van-field
      value="{{inputValue}}"
      placeholder="输入你的需求，例如：不知道吃什么推荐一下"
      bind:change="onInputChange"
      bind:confirm="onSend"
    />
    <van-button type="primary" bind:click="onSend">发送</van-button>
  </view>
  
  <view class="chat-area">
    <view wx:for="{{messages}}" wx:key="index" class="message {{item.type}}">
      <view class="avatar">{{item.type == 'user' ? '我' : 'AI'}}</view>
      <view class="content">{{item.content}}</view>
    </view>
    <view wx:if="{{loading}}" class="loading">
      <van-loading type="spinner" size="20px" />
      <text>AI正在思考...</text>
    </view>
  </view>
  
  <view class="suggestions">
    <text class="suggestion-title">热门问题</text>
    <view class="suggestion-list">
      <van-tag wx:for="{{suggestions}}" wx:key="index" bind:click="onSuggestionClick" color="#fff" text-color="#e64340" style="margin: 10rpx;">{{item}}</van-tag>
    </view>
  </view>
</view>