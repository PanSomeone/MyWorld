.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.input-area {
  display: flex;
  margin-bottom: 30rpx;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.input-area van-field {
  flex: 1;
  margin-right: 20rpx;
}

.chat-area {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  min-height: 400rpx;
}

.message {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #e64340;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin: 0 10rpx;
}

.content {
  flex: 1;
  background-color: #f0f0f0;
  padding: 15rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.message.user .content {
  background-color: #e64340;
  color: #fff;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  color: #666;
  font-size: 24rpx;
}

.loading text {
  margin-left: 10rpx;
}

.suggestions {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.suggestion-list {
  display: flex;
  flex-wrap: wrap;
}